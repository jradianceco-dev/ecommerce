# =============================================
# JRADIANCE E-Commerce Environment Variables
# =============================================

# Copy this file to .env.local and fill in your values


# SUPABASE CONFIGURATION
# Get from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key - KEEP SECRET! Only used in server actions
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here




# FLUTTERWAVE PAYMENT GATEWAY
# Get from: https://dashboard.flutterwave.com
# Use test keys for development, live keys for production
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key_here
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key_here
FLUTTERWAVE_ENCRYPTION_KEY=your_flutterwave_encryption_key_here
# Flutterwave Webhook Hash (optional but recommended)
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_webhook_secret_here

# ------------------------------------------------------------------------------------------------------
# ------------------------------------------------------------------------------------------------------
# PAYSTACK PAYMENT GATEWAY NO LONGER IN USE - SWITCHED TO FLUTTERWAVE FOR BETTER FEATURES AND LOWER FEES
# PAYSTACK PAYMENT GATEWAY
# Get from: https://dashboard.paystack.com/#/settings/api
# Use test keys for development, live keys for production
# PAYSTACK_SECRET_KEY=sk_test_076fbf246ab3a50b141595894d43c6cefdb3f281
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_ad0b2e04eabdf0fc4481a8c27997d467158b6e07
# ------------------------------------------------------------------------------------------------------
# ------------------------------------------------------------------------------------------------------
# WEBSITE URLs
# Your production domain (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://jradianceco.com
NEXT_PUBLIC_SITE_URL=https://jradianceco.com


# -------------------------------------------------------------------------
# -------------------------------------------------------------------------
# FTP NO LONGER IN USE - SWITCHED TO SUPABASE STORAGE FOR COST OPTIMIZATION
